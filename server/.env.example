DATABASE_URL=postgresql://user:password@localhost:5432/notesapp
JWT_SECRET=change-me-to-a-random-secret
PORT=3001

# Password reset: must match the URL users open in the browser (no trailing slash). Wrong value = broken links in emails.
APP_PUBLIC_URL=http://localhost:5173

# SMTP — without SMTP_HOST, forgot-password returns success for privacy but does not send mail; the app will warn that email is not configured.
# Gmail: SMTP_HOST=smtp.gmail.com SMTP_PORT=587 SMTP_SECURE=false — use an App Password on the Google account, not your normal password.
# If send still fails: check API terminal for [mail] / [auth] logs. For self-signed TLS in dev only: SMTP_TLS_REJECT_UNAUTHORIZED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=NoteTasks <noreply@example.com>
# SMTP_TLS_REJECT_UNAUTHORIZED=false

# In production, email must work. In local dev (NODE_ENV not production), if SMTP fails the API still returns a one-time reset URL in the UI.
# Set to true to expose that fallback even when NODE_ENV=production (not recommended on public hosts).
# DEV_PASSWORD_RESET_LINK=true

# Trust X-Forwarded-For when behind a reverse proxy (e.g. Railway). Set TRUST_PROXY=true if rate limits see wrong IPs.
# TRUST_PROXY=true

# Jarvis: Ollama origin reachable from this API (no path). Required for assistant; probe uses GET /api/version (2s timeout).
# Local: http://127.0.0.1:11434
# Hosted API + Ollama on your PC: use a tunnel https origin (ngrok, Tailscale Funnel, etc.) — not localhost on Railway.
#
# Tailscale Funnel: https://tailscale.com/kb/1223/funnel — npm run tunnel:ollama:tailscale
# Cloudflare quick tunnel: npm run tunnel:ollama:cloudflare
# LocalTunnel: npm run tunnel:ollama
# ngrok / Cloudflare / *.ts.net: server adds extra fetch headers for those host patterns when needed.
OLLAMA_BASE_URL=
OLLAMA_MODEL=llama3.2
