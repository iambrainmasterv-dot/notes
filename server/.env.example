DATABASE_URL=postgresql://user:password@localhost:5432/notesapp
JWT_SECRET=change-me-to-a-random-secret
PORT=3001

# Password reset emails: public URL of the web app (no trailing slash). Used in reset links.
APP_PUBLIC_URL=http://localhost:5173

# SMTP — required for forgot-password emails to actually send (Gmail app password, SendGrid, Mailgun, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=NoteTasks <noreply@example.com>

# Trust X-Forwarded-For when behind a reverse proxy (e.g. Railway). Set TRUST_PROXY=true if rate limits see wrong IPs.
# TRUST_PROXY=true

# Assistant: Ollama must be reachable from this server. Probe uses /api/version (2s timeout).
# Priority: each user's "Ollama base URL" in Settings → Jarvis (DB) overrides OLLAMA_BASE_URL below.
#
# --- Local (API + Ollama on same PC) ---
# OLLAMA_BASE_URL=http://127.0.0.1:11434  (repo root: npm run dev:local), or leave unset and set URL in Settings.
#
# --- Railway + Ollama on your laptop ---
# Save the tunnel origin in Settings → Jarvis, or set OLLAMA_BASE_URL here / on Railway.
#
# --- Tunnels that often work when ngrok / Cloudflare quick return 403 ---
#
# LocalTunnel (no account; URL changes each run):
#   1) Start Ollama first (curl http://127.0.0.1:11434/api/version works).
#   2) From repo root:  npm run tunnel:ollama   (or tunnel:ollama:verbose to see requests)
#   3) Keep that terminal open. Use the printed https://....loca.lt origin in Settings → Jarvis.
#
# If the browser shows "503 - Tunnel unavailable":
#   - The lt process exited, or Ollama wasn't up when lt started — restart both in that order.
#   - Firewall blocking Node — allow Node.js / npx for private networks.
#   - Try another network (e.g. phone hotspot); some ISPs break inbound callbacks to the lt client.
#   - LocalTunnel's shared service is flaky — use Tailscale Funnel or SSH localhost.run below.
#
# localhost.run (OpenSSH on Windows; no npm): after Ollama is up:
#   ssh -o StrictHostKeyChecking=accept-new -R 80:127.0.0.1:11434 nokey@localhost.run
#   It prints an https URL — use that origin as Ollama base (may change each session).
#
# Tailscale Funnel (Tailscale account; stable if you use your tailnet hostname):
#   https://tailscale.com/kb/1223/funnel
#   Example flow: enable Funnel in admin console, then on the PC:  tailscale funnel 11434
#
# Zrok (open-source, optional self-host):  https://zrok.io/
#
# ngrok / Cloudflare quick: server adds extra headers for *.ngrok* and *.trycloudflare.com when needed.
OLLAMA_BASE_URL=
OLLAMA_MODEL=llama3.2
