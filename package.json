{
  "name": "notesapp",
  "private": true,
  "version": "0.1.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:local": "concurrently -k -n api,web -c cyan,magenta \"npm run dev --prefix server\" \"vite\"",
    "tunnel:ollama": "npx --yes localtunnel --port 11434 --local-host 127.0.0.1",
    "tunnel:ollama:verbose": "npx --yes localtunnel --port 11434 --local-host 127.0.0.1 --print-requests",
    "tunnel:ollama:cloudflare": "cloudflared tunnel --url http://127.0.0.1:11434",
    "tunnel:ollama:cf": "cloudflared tunnel --url http://127.0.0.1:11434",
    "tunnel:ollama:tailscale": "tailscale funnel 11434",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "cloudflared": "^0.7.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0"
  }
}
